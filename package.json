{
  "name": "@consilioweb/payload-admin-ui-pro",
  "version": "0.2.6",
  "description": "Payload CMS 3 plugin — professional admin UI with 8 themes, dashboard builder, calendar/kanban/gallery views, command palette, notifications, keyboard shortcuts, collaboration presence, field enhancements, and activity audit trail",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      }
    },
    "./views": {
      "import": {
        "types": "./dist/views.d.ts",
        "default": "./dist/views.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "payload",
    "payload-cms",
    "payload-plugin",
    "admin-ui",
    "dashboard",
    "list-views",
    "command-palette",
    "branding",
    "kanban",
    "cards",
    "gallery",
    "activity-feed",
    "customization",
    "calendar",
    "notifications",
    "keyboard-shortcuts",
    "collaboration",
    "bulk-edit",
    "theme-marketplace",
    "dnd-kit",
    "nextjs",
    "react",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pOwn3d/payload-admin-ui-pro.git"
  },
  "homepage": "https://github.com/pOwn3d/payload-admin-ui-pro#readme",
  "bugs": {
    "url": "https://github.com/pOwn3d/payload-admin-ui-pro/issues"
  },
  "author": "ConsilioWEB <contact@consilioweb.fr> (https://consilioweb.fr)",
  "license": "MIT",
  "peerDependencies": {
    "@payloadcms/next": "^3.0.0",
    "@payloadcms/translations": "^3.0.0",
    "@payloadcms/ui": "^3.0.0",
    "next": "^14.0.0 || ^15.0.0 || ^16.0.0",
    "payload": "^3.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@payloadcms/ui": {
      "optional": true
    },
    "@payloadcms/translations": {
      "optional": true
    },
    "@payloadcms/next": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@consilioweb/payload-admin-nav": "^0.12.0",
    "@consilioweb/payload-admin-theme": "^0.2.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@payloadcms/next": "^3.79.0",
    "@payloadcms/translations": "^3.79.0",
    "@payloadcms/ui": "^3.79.0",
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.0.0",
    "jsdom": "^26.0.0",
    "next": "^15.0.0",
    "payload": "^3.79.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2"
  }
}
